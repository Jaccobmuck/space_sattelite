PORT=3001
NODE_ENV=development

# Supabase (REQUIRED in production)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (REQUIRED in production)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

# Client URL (for CORS and Stripe redirects)
CLIENT_URL=http://localhost:5173

# External API URLs (optional - defaults shown)
CELESTRAK_BASE_URL=https://celestrak.org
OPEN_NOTIFY_URL=https://api.open-notify.org
SWPC_BASE_URL=https://services.swpc.noaa.gov

# NASA API key (optional - required for EPIC imagery)
NASA_API_KEY=

# Cache configuration (optional)
TLE_CACHE_DURATION_MS=7200000

# Request timeout (optional - default 10000ms)
REQUEST_TIMEOUT_MS=10000
