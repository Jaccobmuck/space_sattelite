PORT=3001
NODE_ENV=development
CELESTRAK_BASE_URL=https://celestrak.org
OPEN_NOTIFY_URL=http://api.open-notify.org
SWPC_BASE_URL=https://services.swpc.noaa.gov

# Authentication (JWT secrets must be at least 64 characters in production)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

# Client URL (for CORS and Stripe redirects)
CLIENT_URL=http://localhost:5173

# Database (defaults to local SQLite file if not set)
DATABASE_URL=

# Request timeout in milliseconds
REQUEST_TIMEOUT_MS=10000
