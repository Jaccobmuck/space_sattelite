{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Client (Vite)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "client",
      "port": 5173,
      "autoPort": true
    },
    {
      "name": "Server (Express/tsx)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "server",
      "port": 3001
    },
    {
      "name": "Full Stack (Client + Server)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": ".",
      "port": 5173
    }
  ]
}
